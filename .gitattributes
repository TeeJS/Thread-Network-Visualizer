# Force LF on files that must be LF in the built Docker image.
# entrypoint.sh with CRLF would fail with `env: 'sh\r': No such file or directory`.
Dockerfile       text eol=lf
*.sh             text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.conf           text eol=lf
*.json           text eol=lf
.dockerignore    text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf
